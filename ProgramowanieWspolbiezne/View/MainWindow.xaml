<Window x:Class="View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pozdrawiam" Height="540" Width="800">
	<Grid Margin="12">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="12"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
			<TextBlock Text="Liczba kul:" VerticalAlignment="Center" Margin="0,0,8,0"/>
			<TextBox Width="80"
                     Text="{Binding BallsCount, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"
                     Margin="0,0,12,0"/>
			<Button Content="Start" Width="80" Margin="0,0,8,0"
                    Command="{Binding StartCommand}"/>
			<Button Content="Stop" Width="80"
                    Command="{Binding StopCommand}"/>
		</StackPanel>

		<Border Grid.Row="2"
                BorderBrush="Black"
                BorderThickness="3"
                Background="#1e6932"
                Width="{Binding PlayfieldWidth}"
                Height="{Binding PlayfieldHeight}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top">
			<Grid>
				<ItemsControl ItemsSource="{Binding Balls}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<Canvas />
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>

					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Ellipse Fill="Purple"
                                     Stroke="Black"
                                     StrokeThickness="1"
                                     Width="{Binding Diameter}"
                                     Height="{Binding Diameter}"
                                     Canvas.Left="{Binding X}"
                                     Canvas.Top="{Binding Y}" />
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</Grid>
		</Border>
	</Grid>
</Window>